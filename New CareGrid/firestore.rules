rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to check if user owns the document (no PII exposure)
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Helper to check if user is a designated administrator/dev
    function isDev() {
      return isSignedIn() && (
        request.auth.uid == 'BS3htAuD5GdbUXawqniaiuY0clR2' ||
        (request.auth.token != null && 'email' in request.auth.token && request.auth.token.email == 'saikatdhara91@gmail.com')
      );
    }

    // Users Collection
    match /users/{userId} {
      allow get: if isOwner(userId) || isDev();
      allow create, update: if isOwner(userId) || isDev();
      allow list, delete: if isDev();
    }

    // Appointments Collection
    match /appointments/{appointmentId} {
      allow get, list: if isSignedIn() && (
        ('patientUserId' in resource.data && resource.data.patientUserId == request.auth.uid) || 
        isDev()
      );
      allow create: if isSignedIn() && 'patientUserId' in request.resource.data && request.resource.data.patientUserId == request.auth.uid;
      allow update: if isSignedIn() && (
        ('patientUserId' in resource.data && resource.data.patientUserId == request.auth.uid) || 
        isDev()
      );
      allow delete: if isDev();
    }

    // Validation helper for Medicine Reminders
    function isValidReminder(data) {
      return data.keys().hasAll(['id', 'userId', 'medicineName', 'dosage', 'timing', 'frequency', 'isActive', 'createdAt']) &&
             data.keys().size() == 8 &&
             data.id is string && data.id.size() <= 128 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.medicineName is string && data.medicineName.size() <= 200 &&
             data.dosage is string && data.dosage.size() <= 200 &&
             data.timing is string && data.timing.size() <= 200 &&
             data.frequency is string && data.frequency.size() <= 100 &&
             data.isActive is bool &&
             data.createdAt is string && data.createdAt.size() <= 64;
    }

    // Medicine Reminders Collection
    match /reminders/{reminderId} {
      allow read, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && isValidReminder(request.resource.data);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && isValidReminder(request.resource.data);
    }

    // Validation helper for Booking Logs
    function isValidBookingLog(data) {
      return data.keys().hasAll(['name', 'email', 'createdAt']) &&
             data.name is string && data.name.size() <= 200 &&
             data.email is string && data.email.size() <= 200 &&
             data.createdAt is string && data.createdAt.size() <= 64;
    }

    // Visitor Booking Audit Logs
    match /booking_logs/{logId} {
      allow create: if isValidBookingLog(request.resource.data);
      allow read, update, delete: if isDev();
    }

    // Test Collection for Connection Verification
    match /test/{docId} {
      allow read, write: if true;
    }
  }
}
